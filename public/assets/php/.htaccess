# =============================================================================
# .htaccess — Contact Form Security Hardening
# =============================================================================
# Version:  2.1.0
# Date:     2026-03-27
# Basis:    Security-Audit + SECURITY-FIX-KONZEPT.md (Phase 1)
# Fixes:    HF-04 (Diagnose-Endpunkte), MF-01 (.htaccess-Lücken),
#           MF-05 (.env.compose), + PHP-Klassen-Schutz
# =============================================================================
#
# CHANGELOG:
#   v2.1.0 (2026-03-27) — Disposable-Domain-Blacklist-Dateien gesperrt
#     - domain-blacklist-custom.txt und domain-blacklist-upstream.txt gesperrt
#     - Alle .txt-Dateien im Verzeichnis pauschal gesperrt (Defense-in-Depth)
#     - Bezug: docs/contact-form-feature/KONZEPT-EMAIL-SPAM-VALIDIERUNG.md
#
#   v2.0.0 (2026-03-24) — Security Hardening
#     - Diagnose-Endpunkte gesperrt (HF-04)
#     - Alle env-Dateien geschützt inkl. app.env, .env.compose (MF-01/MF-05)
#     - PHP-Klassen vor direktem HTTP-Aufruf geschützt
#     - Markdown-Dateien gesperrt (enthalten Server-Pfade)
#     - Options -Indexes hinzugefügt
#     - Alte auskommentierte Varianten entfernt
#
#   v1.0.0 (2025-10-04) — Initial
#     - Basis-Schutz für .env-Dateien
#     - AbuseLogger.php gesperrt
#     - Log-Dateien gesperrt
# =============================================================================


# --- 1) PHP-Fehleranzeige deaktivieren ---
# Verhindert, dass PHP-Fehler Pfade oder Secrets im Browser leaken.
php_flag display_errors Off


# --- 2) Verzeichnislistung deaktivieren ---
# Ohne dieses Flag zeigt Apache bei fehlendem index.php den Ordnerinhalt.
Options -Indexes


# --- 3) Environment-Dateien sperren ---
# Schützt ALLE env-Varianten: .env, .env.prod, .env.local, .env.compose
# PLUS app.env und die Example-Datei (enthält Feld-Beschreibungen für Angreifer)
<FilesMatch "\.(env|env\.prod|env\.local|env\.compose)$">
  Require all denied
</FilesMatch>
<Files "app.env">
  Require all denied
</Files>
<Files ".env.compose">
  Require all denied
</Files>
<Files ".env.prod.example.v3">
  Require all denied
</Files>


# --- 4) Diagnose-Endpunkte sperren (HF-04) ---
# KRITISCH: Diese Dateien geben PHP-Version, Dateipfade, SMTP-Credentials
# und Autoload-Status preis. _probe.php zeigt sogar SMTP_PASS im Klartext!
#
# Bei Debugging-Bedarf: vorübergehend auskommentieren,
# danach SOFORT wieder aktivieren!
<FilesMatch "^(_probe|_smtp_probe|_env_check|_autoload_check|selftest|health-check|mail-transport-diag|debug_session)\.php$">
  Require all denied
</FilesMatch>


# --- 5) PHP-Klassen vor direktem HTTP-Aufruf schützen ---
# Diese Dateien sind nur als require_once innerhalb anderer PHP-Dateien gedacht.
# Direkter Aufruf per Browser kann Fehlermeldungen mit Pfaden leaken.
<FilesMatch "^(AbuseLogger|BlocklistManager|ExtendedLogger|ContactFormValidator-v2|LoginRateLimiter|helpers)\.php$">
  Require all denied
</FilesMatch>


# --- 6) Dokumentation und sensible Textdateien sperren ---
# Markdown-Dateien enthalten Server-Pfade, Berechtigungsstrukturen und
# Security-Konzepte — nicht für die Öffentlichkeit bestimmt.
# Textdateien enthalten Blocklisten, IP-Listen und Konfigurationsdaten.
# Shell-Skripte enthalten Server-Pfade und Deployment-Details.
<FilesMatch "\.(md|sh|txt)$">
  Require all denied
</FilesMatch>


# --- 7) Log-Dateien (Backup-Schutz) ---
# Hauptschutz liegt in logs/.htaccess — dies ist eine zweite Sicherheitsebene.
<FilesMatch "\.log$">
  Require all denied
</FilesMatch>


# --- 8) Redirect Dashboard-HTML zu Login (optional) ---
# Auskommentiert: Nur aktivieren, falls eine dashboard.html existiert.
# RewriteEngine On
# RewriteRule ^dashboard\.html$ ./dashboard-login.php [R,L]
